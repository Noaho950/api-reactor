{
  "name": "api-reactor",
  "displayName": "API Reactor",
  "description": "Load API endpoint definitions from any URL (local file, local server, or remote) and test them directly from the VS Code sidebar.",
  "version": "0.0.1",
  "publisher": "NoahBit",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Noaho950/api-reactor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "api-reactor.refresh",
        "title": "Refresh API Tests",
        "icon": "$(refresh)"
      },
      {
        "command": "api-reactor.preview",
        "title": "Preview API Request",
        "icon": "$(preview)"
      },
      {
        "command": "api-reactor.run",
        "title": "Run API Request",
        "icon": "$(play)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apiReactor",
          "title": "API Reactor",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "apiReactor": [
        {
          "id": "apiReactorView",
          "name": "API Endpoints"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "api-reactor.refresh",
          "when": "view == apiReactorView",
          "group": "navigation",
          "icon": "$(refresh)"
        }
      ],
      "view/item/context": [
        {
          "command": "api-reactor.preview",
          "when": "view == apiReactorView && viewItem == 'endpoint'",
          "group": "inline",
          "icon": "$(preview)"
        },
        {
          "command": "api-reactor.run",
          "when": "view == apiReactorView && viewItem == 'endpoint'",
          "group": "inline",
          "icon": "$(play)"
        }
      ]
    },
    "configuration": {
      "title": "API Reactor",
      "properties": {
        "apiReactor.baseUrl": {
          "type": "string",
          "default": "http://localhost:3000/api",
          "description": "Base URL for all API requests (e.g., http://localhost:3000/api or https://api.example.com/v1)"
        },
        "apiReactor.definitionsUrl": {
          "type": "string",
          "default": "http://localhost:3000/api-tests.json",
          "description": "URL to fetch API endpoint definitions. Supports: http://, https://, or file:///path/to/file.json"
        },
        "apiReactor.autoFetch": {
          "type": "boolean",
          "default": false,
          "description": "Automatically fetch API definitions when VS Code starts."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "typescript": "^5.3.0"
  }
}
